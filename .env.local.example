# Rekening Bank untuk pembayaran manual
NEXT_PUBLIC_BANK_NAME=BCA
NEXT_PUBLIC_BANK_NUMBER=1234567890
NEXT_PUBLIC_BANK_HOLDER=Nama Toko Anda

# Site config
NEXT_PUBLIC_SITE_NAME=iUnlock.id
NEXT_PUBLIC_SITE_URL=https://iunlock.id
